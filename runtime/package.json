{
  "name": "runtime",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "build": "vite build",
    "demo": "vite --host 127.0.0.1 --port 4173",
    "validate:shaders": "node scripts/validate-shaders.mjs",
    "validate:api": "node scripts/validate-runtime-api.mjs",
    "validate:imports": "node scripts/validate-imports.mjs",
    "validate:local-fallback": "node scripts/validate-local-fallback.mjs",
    "validate": "npm run validate:shaders && npm run validate:api && npm run validate:imports && npm run validate:local-fallback",
    "test": "npm run validate && playwright test --project=gpu-headed --grep @webgpu",
    "test:gpu": "playwright test --project=gpu-headed --grep @webgpu",
    "test:gpu:investigate": "playwright test --project=gpu-headed tests/gpu-investigation.spec.ts",
    "test:chrome": "playwright test --project=chrome-webgpu --grep @webgpu"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@codemirror/commands": "^6.10.0",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/state": "^6.5.2",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.38.6",
    "@webgpu/types": "^0.1.68",
    "typescript": "^5.7.0",
    "vite": "^7.0.0",
    "typegpu": "^0.8.2"
  }
}
